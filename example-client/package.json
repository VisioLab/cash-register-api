{
  "name": "example-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "@npmcli/run-script@<=7.0.2": "7.0.2",
      "pacote@<=17.0.4": "17.0.4",
      "@asyncapi/generator@<=3.2.0": "3.2.0",
      "tar@<=7.5.4": "7.5.4",
      "make-fetch-happen@<=14.0.1": "14.0.1",
      "npm-registry-fetch@<=18.0.1": "18.0.1",
      "dompurify@<=3.2.4": "3.2.4",
      "@asyncapi/bundler@<=0.6.4": "0.6.4",
      "tough-cookie@<=4.1.3": "4.1.3",
      "form-data@<=2.5.4": "2.5.4",
      "ajv@<=6.12.3": "6.12.3",
      "qs@<=6.14.1": "6.14.1"
    }
  },
  "scripts": {
    "start": "pnpm run build && pnpm run preview",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "generateTypes": "node --loader ts-node/esm ./src/generateTypes.ts",
    "generateDocs": "pnpm exec asyncapi generate fromTemplate ../api.yml @asyncapi/html-template@0.28.4 -p singleFile=true -p favicon=public/favicon.png  -o ../docs",
    "validate": "pnpm exec asyncapi validate ../api.yml | grep -q \"0 errors\" || (echo \"Error: '0 errors' not found in output\" && exit 1)"
  },
  "dependencies": {
    "@asyncapi/cli": "^5.0.1",
    "@asyncapi/generator": "^3.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^7.0.0",
    "lodash": "^4.17.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@asyncapi/parser": "^1.15.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "json-schema-to-typescript": "^15.0.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.0",
    "vite": "^6.3.0"
  }
}
